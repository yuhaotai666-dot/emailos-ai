# ---- LLM provider ----
# Choose the provider with LLM_PROVIDER: "anthropic" | "openai" | "mock".
# If the selected provider's key is empty (or provider is "mock"), the backend
# still runs using deterministic mock outputs (no crash, no cost).
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Model id for the selected provider. Swap without touching code.
#   anthropic -> a Claude id, e.g. claude-sonnet-4-6 (verify against Anthropic docs)
#   openai    -> an OpenAI id, e.g. gpt-4o
LLM_MODEL=claude-sonnet-4-6

# ---- Email source ----
EMAIL_PROVIDER=mock

# ---- Persistence ----
DATABASE_PROVIDER=local

# ---- Agent loop tuning ----
MAX_DRAFT_RETRIES=2
MIN_DRAFT_SCORE=8

# ---- CORS (comma-separated). Covers Vite dev + Lovable preview domains. ----
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://*.lovable.app,https://*.lovableproject.com
